generator client {
   provider = "prisma-client-js"
}

datasource db {
   provider = "postgresql"
}

model Project {
   id          String   @id @default(cuid())
   title       String
   category    String
   description String
   image       String
   modalImage  String
   link        String?
   code        String?
   stack       String[]
   order       Int      @default(0)
   featured    Boolean  @default(false)
   createdAt   DateTime @default(now())
   updatedAt   DateTime @updatedAt
}

model GalleryImage {
   id        String   @id @default(cuid())
   original  String
   thumbnail String
   caption   String?
   order     Int      @default(0)
   createdAt DateTime @default(now())
}

model SiteConfig {
   id        String   @id @default(cuid())
   key       String   @unique
   value     String
   updatedAt DateTime @updatedAt
}

model Technology {
   id       String @id @default(cuid())
   name     String @unique
   iconKey  String
   category String @default("Other")
   order    Int    @default(0)
}

model PageView {
   id        String   @id @default(cuid())
   path      String
   visitorId String
   userAgent String?
   country   String?
   city      String?
   referrer  String?
   createdAt DateTime @default(now())

   @@index([createdAt])
   @@index([path])
}
